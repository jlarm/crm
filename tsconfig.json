{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "strict": false,
        "jsx": "preserve",
        "lib": ["ESNext", "DOM"],
        "types": ["vite/client"],
        "baseUrl": ".",
        "paths": {
            "@/*": ["resources/js/*"]
        },
        "skipLibCheck": true,
        "verbatimModuleSyntax": true
    },
    "include": ["resources/js/**/*"],
    "exclude": ["node_modules", "vendor", "public"]
}
